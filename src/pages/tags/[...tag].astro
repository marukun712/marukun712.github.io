---
import { getCollection } from "astro:content";
import { File, Tag, Minus } from "lucide-react";
import Layout from "@/layouts/Layout.astro";
import Breadcrumbs from "@/components/Breadcrumbs.astro";
import TagList from "@/components/TagList";
import { trimRelPath, toSlug } from "@/utils/slug";

export async function getStaticPaths() {
  const notes = await getCollection("notes");
  const tagSet = new Set<string>();

  for (const note of notes) {
    for (const tag of note.data.tags ?? []) {
      const parts = tag.split("/");
      for (let i = 1; i <= parts.length; i++) {
        const nested = parts.slice(0, i).join("/");
        tagSet.add(nested);
      }
    }
  }

  return Array.from(tagSet).map((tag) => ({
    params: { tag }, // Obsidian tags are already slugified
  }));
}

type Props = {
  tag: string;
};

const { tag = "" } = Astro.params;
const splitTag = tag === "" ? [] : tag?.split("/");

const notes = await getCollection("notes");

// Notes that have the current tag prefix
const matchingNotes = notes.filter((note) =>
  note.data.tags?.some((t) => t.startsWith(tag)),
);

// Tags nested immediately under the current tag
const nestedTags = new Set<string>();
for (const note of matchingNotes) {
  for (const noteTag of note.data.tags ?? []) {
    if (noteTag.slice(0, tag.length + 1) === tag + "/" || tag === "") {
      const parts = noteTag.slice(tag.length).replace(/^\//, "").split("/");
      if (parts.length > 0 && parts[0] !== "") {
        nestedTags.add(parts[0]);
      }
    }
  }
}

type tagEntry = {
  type: "tag";
  name: string;
  href: string;
};
type noteEntry = {
  type: "note";
  name: string;
  href: string;
  tags: string[];
};

// Notes or nested tags
const items: (tagEntry | noteEntry)[] = [
  ...Array.from(nestedTags)
    .map(
      (name) =>
        ({
          type: "tag",
          name,
          href: `/tags/${[...splitTag, name].join("/")}`,
        }) as tagEntry,
    )
    .sort((a, b) => a.name.toLowerCase().localeCompare(b.name.toLowerCase())),
  ...matchingNotes
    .filter((note) => note.data.tags?.includes(tag))
    .map((note) => {
      const path = trimRelPath(note.filePath) ?? note.id;
      return {
        type: "note",
        name: path.split("/").pop(),
        href: `/notes/${toSlug(path)}`,
        tags: note.data.tags || [],
      } as noteEntry;
    })
    .sort((a, b) => a.name.toLowerCase().localeCompare(b.name.toLowerCase())),
];
---

<Layout>
  <Breadcrumbs path={tag} type="tags" isFolder={true} />
  <div class="rounded-md border mt-8">
    <table class="table-fixed border-collapse w-full">
      <thead>
        <tr>
          <th class="w-full"></th>
          <th class="align-right w-30"></th>
        </tr>
      </thead>
      <tbody>
        <tr class="bg-muted/50">
          <td colspan="2" class="py-2 px-4">
            <div class="flex items-center gap-4 text-muted-foreground">
              <span class="flex items-center gap-1">
                <Tag className="w-[1em] mr-1" />
                {nestedTags.size} nested tags</span
              >
              <span class="flex items-center gap-1">
                <File className="w-[1em] mr-1" />
                {matchingNotes.length} notes</span
              >
            </div>
          </td>
        </tr>
        {
          items.map((item) => (
            <tr class="border-t">
              <td class="py-2 px-4 min-w-0">
                <div class="flex items-center gap-2">
                  {item.type === "tag" ? (
                    <Tag className="flex-none w-[1em]" />
                  ) : (
                    <File className="flex-none w-[1em]" />
                  )}
                  <a
                    href={item.href}
                    class="truncate hover:text-primary"
                  >
                    {item.name}
                  </a>
                </div>
              </td>
              <td class="px-4">
                {item.type === "note" && (
                  <div class="w-auto items-center">
                    {item.tags.length > 0 ? (
                      <TagList
                        tags={item.tags}
                        showPreview={false}
                        client:load
                      />
                    ) : (
                      <Minus className="w-4" />
                    )}
                  </div>
                )}
              </td>
            </tr>
          ))
        }
      </tbody>
    </table>
  </div>
</Layout>
